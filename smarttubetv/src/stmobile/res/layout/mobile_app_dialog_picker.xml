<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom-sheet content for a collapsed single-choice setting: a title followed by the
     category's options rendered as the standard expanded radio list (reuses
     MobileAppDialogAdapter). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/mobile_background"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/picker_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:textColor="@color/mobile_accent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/picker_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>

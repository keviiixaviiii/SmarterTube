<?xml version="1.0" encoding="utf-8"?>
<!--
    Single-phone sign-in. The OAuth device-code flow is mandatory (it is the only flow
    that yields InnerTube-compatible credentials), but the QR and second-device framing
    are dropped: the code is pre-filled into the URL and opened in an in-app Custom Tab.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/mobile_background">

    <LinearLayout
        android:id="@+id/signin_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/signin_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/signin_view_title"
            android:textColor="@color/mobile_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/signin_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/mobile_signin_instructions"
            android:textColor="@color/mobile_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/signin_code_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/mobile_signin_code_label"
            android:textColor="@color/mobile_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/signin_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/mobile_accent"
            android:textSize="36sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/signin_browser_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/mobile_signin_continue" />

        <!-- Shown after the user has tapped Continue and may have completed sign-in
             in the Custom Tab. Brings the app back to the foreground manually so the
             user is not stranded looking at the YouTube activation page if the
             polling-detected auto-return is slow. -->
        <Button
            android:id="@+id/signin_done_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:text="@string/mobile_signin_done_return"
            style="?android:attr/borderlessButtonStyle" />

        <!-- Error / recovery block. Shown when YTSignInPresenter delivers an error
             through the showCode(message, "") overload — typically a DNS failure on
             networks where www.youtube.com is filtered (Pi-hole / NextDNS / etc.).
             The "Switch DNS" button escalates PlayerTweaksData to DNS_TYPE_GOOGLE and
             restarts the app so OkHttp picks up the new resolver. -->
        <LinearLayout
            android:id="@+id/signin_error_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/signin_error_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/mobile_signin_error_title"
                android:textColor="@color/mobile_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/signin_error_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/mobile_text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/signin_switch_dns_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/mobile_signin_switch_dns" />

            <Button
                android:id="@+id/signin_retry_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/mobile_signin_retry"
                style="?android:attr/borderlessButtonStyle" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

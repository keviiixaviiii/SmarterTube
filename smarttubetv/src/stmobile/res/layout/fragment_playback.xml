<?xml version="1.0" encoding="utf-8"?>
<!--
    stmobile override of the player activity content (main: a bare full-screen PlaybackFragment).

    Adds an upright/portrait mode: the player fragment is constrained to a 16:9 strip at the top
    and a below-video panel (title + channel + up-next list) fills the rest. The constraints are
    switched at runtime by MobilePlaybackFragment.applyMobileLayout() — this XML's defaults are
    the full-screen (landscape / Shorts / PiP) state so the player looks unchanged until the
    portrait state is explicitly applied. The fragment class is the mobile subclass which feeds
    the panel; the tag must stay @string/playback_tag (PlaybackActivity looks the fragment up by
    tag and checks instanceof PlaybackFragment).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mobile_playback_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <fragment
        android:id="@+id/playback_controls_fragment"
        android:name="com.liskovsoft.smartyoutubetv2.mobile.ui.playback.MobilePlaybackFragment"
        android:tag="@string/playback_tag"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!--
        Shorts pager filmstrip posters: full-screen thumbnails of the previous / next Short.
        Parked one screen-height above / below and slid in with the drag (see
        MobilePlaybackFragment.setShortsPageTranslation). Hidden except during an active swipe.
    -->
    <ImageView
        android:id="@+id/mobile_shorts_prev_poster"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:background="@android:color/black"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/mobile_shorts_next_poster"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:background="@android:color/black"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Shorts overlay: right-edge action rail (like/dislike/comments/channel).
        Constrained to the right side of the video strip; vertically centered within it.
        Hidden by default; revealed/hidden by MobilePlaybackFragment's auto-hide logic.
    -->
    <include
        layout="@layout/mobile_shorts_action_rail"
        android:id="@+id/mobile_shorts_action_rail"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="@id/playback_controls_fragment"
        app:layout_constraintTop_toTopOf="@id/playback_controls_fragment"
        app:layout_constraintBottom_toBottomOf="@id/playback_controls_fragment"
        android:layout_marginEnd="4dp" />

    <!--
        Shorts overlay: back button, top-left corner of the video strip.
        Hidden by default; revealed/hidden with the action rail.
    -->
    <ImageButton
        android:id="@+id/mobile_shorts_back_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_shorts_back"
        android:background="@android:color/transparent"
        android:scaleType="center"
        android:visibility="invisible"
        android:contentDescription="Back"
        app:layout_constraintStart_toStartOf="@id/playback_controls_fragment"
        app:layout_constraintTop_toTopOf="@id/playback_controls_fragment"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp" />

    <!--
        Shorts overlay: centred play/pause indicator (not interactive — tap-anywhere logic in
        MobilePlaybackFragment.handleShortsTouchEvent shows/fades this icon on each tap).
    -->
    <ImageView
        android:id="@+id/mobile_shorts_play_pause_btn"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_shorts_play"
        android:scaleType="center"
        android:clickable="false"
        android:focusable="false"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/playback_controls_fragment"
        app:layout_constraintBottom_toBottomOf="@id/playback_controls_fragment"
        app:layout_constraintStart_toStartOf="@id/playback_controls_fragment"
        app:layout_constraintEnd_toEndOf="@id/playback_controls_fragment" />

    <!--
        Shorts info bar: title + channel name shown BELOW the 9:16 video strip.
        Always visible while in Shorts mode (does not auto-hide). Replaces the regular
        up-next panel for Shorts; hidden when the regular panel is shown.
    -->
    <LinearLayout
        android:id="@+id/mobile_shorts_info_bar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="16dp"
        android:paddingEnd="80dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/playback_controls_fragment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/mobile_shorts_nav_bar">

        <TextView
            android:id="@+id/shorts_bar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/shorts_bar_channel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textColor="#FFAAAAAA"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/mobile_below_video_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/playback_controls_fragment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Title row; tapping it toggles the description below (chevron flips). -->
        <LinearLayout
            android:id="@+id/mobile_video_title_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/mobile_video_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/mobile_video_expand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:textColor="#FFCCCCCC"
                android:textSize="26sp"
                android:text="▾" />
        </LinearLayout>

        <TextView
            android:id="@+id/mobile_video_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:textColor="#FFDDDDDD"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:maxLines="12"
            android:scrollbars="vertical"
            android:visibility="gone" />

        <!-- Meta block: channel name with subscribers below (left); views with likes below (right). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mobile_video_channel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/mobile_video_subs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textColor="#FFAAAAAA"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:gravity="end">

                <TextView
                    android:id="@+id/mobile_video_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/mobile_video_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textColor="#FFAAAAAA"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mobile_up_next_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="6dp" />
    </LinearLayout>

    <!--
        Shorts bottom navigation bar: Home / Shorts / Subscriptions / You.
        Visible only in Shorts mode (state 2); managed by MobilePlaybackFragment.applyMobileLayout().
    -->
    <LinearLayout
        android:id="@+id/mobile_shorts_nav_bar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="#DD000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/shorts_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_shorts_nav_home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textSize="11sp" android:text="Home" android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/shorts_nav_shorts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_shorts_nav_shorts"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textSize="11sp" android:text="Shorts" android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/shorts_nav_subscriptions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_shorts_nav_subs"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textSize="11sp" android:text="Subscriptions" android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/shorts_nav_you"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_shorts_nav_you"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textSize="11sp" android:text="You" android:textColor="@android:color/white"/>
        </LinearLayout>
    </LinearLayout>

    <!--
        Semi-transparent scrim above the "You" profile sheet (covers everything down to the top of
        the sheet, leaving the nav bar bright). Tap-to-dismiss is handled in
        MobilePlaybackFragment.handleShortsTouchEvent (the activity intercepts touches in Shorts
        mode, so the scrim's own onClick can't fire).
    -->
    <View
        android:id="@+id/mobile_shorts_profile_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/mobile_shorts_profile_sheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        "You" profile sheet: drag handle + account header + navigation rows.
        Slides up from the bottom (sitting just above the nav bar) when "You" is tapped.
    -->
    <LinearLayout
        android:id="@+id/mobile_shorts_profile_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/black"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/mobile_shorts_nav_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Drag handle: tap to close. -->
        <FrameLayout
            android:id="@+id/profile_sheet_handle"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="#66FFFFFF" />
        </FrameLayout>

        <!-- Account header: avatar + name + email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">
                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:text="Account" />
                <TextView
                    android:id="@+id/profile_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" />

        <!-- My Channel -->
        <LinearLayout
            android:id="@+id/profile_row_channel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="?android:attr/selectableItemBackground">
            <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="20sp" android:text="📺"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:paddingStart="12dp"
                android:textColor="@android:color/white" android:textSize="15sp"
                android:text="My channel"/>
        </LinearLayout>

        <!-- History -->
        <LinearLayout
            android:id="@+id/profile_row_history"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="?android:attr/selectableItemBackground">
            <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="20sp" android:text="🕐"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:paddingStart="12dp"
                android:textColor="@android:color/white" android:textSize="15sp"
                android:text="History"/>
        </LinearLayout>

        <!-- Playlists -->
        <LinearLayout
            android:id="@+id/profile_row_playlists"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="?android:attr/selectableItemBackground">
            <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="20sp" android:text="📝"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:paddingStart="12dp"
                android:textColor="@android:color/white" android:textSize="15sp"
                android:text="Playlists"/>
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/profile_row_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="?android:attr/selectableItemBackground">
            <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="20sp" android:text="⚙"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:paddingStart="12dp"
                android:textColor="@android:color/white" android:textSize="15sp"
                android:text="Settings"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

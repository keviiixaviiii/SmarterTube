<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom-sheet card background: surface fill with rounded top corners. Used when a short
     single-category sub-dialog (e.g. Video speed) is presented as a bottom card instead of a
     full-screen activity. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/mobile_surface" />
    <corners
        android:topLeftRadius="16dp"
        android:topRightRadius="16dp" />
</shape>
